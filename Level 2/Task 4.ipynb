   "source": [
    "numbers=[1,2,3,4,5]\n",
    "\n",
    "even_numbers=list(filter(lambda x: x % 2 ==0, numbers))\n",
    "\n",
    "cubed_numbers=list(map(lambda x: x ** 3, even_numbers))\n",
    "\n",
    "print(\" Cubed Even Numbers\", cubed_numbers)"
   ]
